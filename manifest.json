{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "1.0.0",
    "default_locale": "en",
    "description": "__MSG_extensionDescription__",
    "developer": {
        "name": "Mohammad Karimi"
    },
    "homepage_url": "https://github.com/karimi-mohammad/smart-tab-grouper",
    "icons": {
        "48": "icons/icon-48.png",
        "96": "icons/icon-96.png"
    },
    "permissions": [
        "tabs",
        "tabGroups",
        "storage"
    ],
    "host_permissions": [
        "https://openrouter.ai/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon-48.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "smart-tab-grouper@mohammadkarimi.ir"
        }
    }
}